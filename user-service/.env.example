# Copy this to .env and fill in your values
# Never commit .env to GitHub!

PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=payment_db

# Redis cache
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
